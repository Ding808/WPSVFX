{
  "name": "wt-powerfx",
  "version": "1.0.0",
  "description": "Enhanced effects for Windows Terminal – keystroke sounds, particle overlay, window shake",
  "keywords": ["windows-terminal", "powerfx", "shader", "particle", "effect"],
  "author": "wt-powerfx contributors",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "wt-powerfx": "dist/index.js"
  },
  "files": [
